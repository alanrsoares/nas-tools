{
  "name": "nas-tools",
  "private": true,
  "version": "1.0.1",
  "description": "NAS tools CLI for managing music files, downloads, and file operations",
  "main": "dist/cli/index.js",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "bin": {
    "nas-tools": "./cli/index.ts"
  },
  "scripts": {
    "build": "tsc && bun run --filter @nas-tools/core build && bun run --filter @nas-tools/server build && bun run --filter @nas-tools/web build",
    "dev": "bun scripts/dev.ts",
    "dev:cli": "bun run cli",
    "dev:server": "bun run --filter @nas-tools/server start",
    "dev:web": "bun run --filter @nas-tools/web dev",
    "start:web": "bun scripts/dev.ts",
    "cockpit": "bun cli/index.ts cockpit",
    "check": "bun run lint && bun run typecheck && bun run test",
    "check:size": "bun scripts/check-file-size.ts",
    "test": "bun test cli",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "format": "biome check --fix .",
    "LINK": "bun run build && bun link"
  },
  "keywords": [
    "cli",
    "nas",
    "music",
    "file-management",
    "download"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "commander": "^14.0.3",
    "dotenv": "^17.4.2",
    "got": "^15.0.5",
    "inquirer": "^13.4.3",
    "music-metadata": "^11.12.3",
    "neverthrow": "^8.2.0",
    "picocolors": "^1.1.1",
    "tiny-invariant": "^1.3.3",
    "true-myth": "^9.3.1",
    "ts-pattern": "^5.9.0",
    "zod": "^4.4.3",
    "zx": "^8.8.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@tsconfig/strictest": "^2.0.8",
    "@types/bun": "^1.3.14",
    "typescript": "^6.0.3"
  }
}
